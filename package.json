{
	"name": "habits",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "react-router dev",
		"build": "react-router build",
		"start": "react-router-serve ./build/server/index.js",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"test": "vitest run",
		"test:watch": "vitest",
		"typecheck": "react-router typegen && tsc",
		"prepare": "husky",
		"db:auth": "pnpx auth@latest generate --config ./app/.server/auth.ts --output ./app/.server/db/auth-schema.ts --yes",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:push": "drizzle-kit push",
		"db:reset": "docker compose down -v && docker compose up -d && sleep 3 && drizzle-kit push",
		"db:studio": "drizzle-kit studio"
	},
	"dependencies": {
		"@base-ui/react": "^1.4.1",
		"@better-auth/passkey": "^1.6.10",
		"@dnd-kit/react": "^0.3.2",
		"@electric-sql/client": "^1.5.16",
		"@electric-sql/react": "^1.0.45",
		"@fontsource-variable/urbanist": "^5.2.7",
		"@js-temporal/polyfill": "^0.5.1",
		"@react-router/node": "7.13.1",
		"@react-router/serve": "7.13.1",
		"@tanstack/browser-db-sqlite-persistence": "^0.1.9",
		"@tanstack/db": "^0.6.5",
		"@tanstack/electric-db-collection": "^0.3.3",
		"@tanstack/react-db": "^0.1.83",
		"@tanstack/react-query": "^5.100.9",
		"better-auth": "^1.6.10",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"drizzle-orm": "^0.45.2",
		"isbot": "^5.1.40",
		"lucide-react": "^0.577.0",
		"pg": "^8.20.0",
		"react": "^19.2.6",
		"react-dom": "^19.2.6",
		"react-router": "7.13.1",
		"shadcn": "^4.7.0",
		"tailwind-merge": "^3.6.0",
		"tw-animate-css": "^1.4.0",
		"zod": "^4.4.3"
	},
	"lint-staged": {
		"*.{js,jsx,ts,tsx,json,jsonc,css}": "pnpm exec biome check --write"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"@biomejs/biome",
			"esbuild",
			"husky"
		]
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.15",
		"@react-router/dev": "7.13.1",
		"@tailwindcss/vite": "^4.3.0",
		"@types/node": "^25.6.2",
		"@types/pg": "^8.20.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"drizzle-kit": "^0.31.10",
		"drizzle-zod": "^0.8.3",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"tailwindcss": "^4.3.0",
		"typescript": "^6.0.3",
		"vite": "^7.3.3",
		"vite-plugin-pwa": "^1.3.0",
		"vite-tsconfig-paths": "^5.1.4",
		"vitest": "^4.1.5",
		"workbox-window": "^7.4.1"
	}
}
