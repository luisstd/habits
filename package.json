{
	"name": "habits",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "react-router dev",
		"build": "react-router build",
		"start": "react-router-serve ./build/server/index.js",
		"lint": "biome check .",
		"format": "biome check --write .",
		"test": "vitest run",
		"test:watch": "vitest",
		"typecheck": "react-router typegen && tsc",
		"db:auth": "pnpx auth@latest generate --config ./app/.server/auth.ts --output ./app/.server/db/auth-schema.ts --yes",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:push": "drizzle-kit push",
		"db:reset": "docker compose down -v && docker compose up -d && sleep 3 && drizzle-kit push"
	},
	"dependencies": {
		"@base-ui/react": "^1.3.0",
		"@better-auth/passkey": "^1.5.5",
		"@dnd-kit/react": "^0.3.2",
		"@electric-sql/client": "^1.5.12",
		"@electric-sql/react": "^1.0.41",
		"@fontsource-variable/urbanist": "^5.2.7",
		"@react-router/node": "7.13.1",
		"@react-router/serve": "7.13.1",
		"@tanstack/db": "^0.5.33",
		"@tanstack/electric-db-collection": "^0.2.41",
		"@tanstack/react-db": "^0.1.77",
		"@tanstack/react-query": "^5.90.21",
		"better-auth": "^1.5.5",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"drizzle-orm": "^0.45.1",
		"isbot": "^5",
		"lucide-react": "^0.577.0",
		"pg": "^8.20.0",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-router": "7.13.1",
		"shadcn": "^4.0.8",
		"tailwind-merge": "^3.5.0",
		"tw-animate-css": "^1.4.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.7",
		"@js-temporal/polyfill": "^0.5.1",
		"@react-router/dev": "7.13.1",
		"@tailwindcss/vite": "^4.1.13",
		"@types/node": "^22",
		"@types/pg": "^8.18.0",
		"@types/react": "^19.2.7",
		"@types/react-dom": "^19.2.3",
		"drizzle-kit": "^0.31.9",
		"drizzle-zod": "^0.8.3",
		"tailwindcss": "^4.1.13",
		"typescript": "^6.0.2",
		"vite": "^7.1.7",
		"vite-tsconfig-paths": "^5.1.4",
		"vitest": "^4.1.2"
	}
}
